<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Readify">
    
    <!-- Базовый стиль для всех кнопок -->
    <Style
        TargetType="{x:Type Button}"
        BasedOn="{StaticResource BaseStyle}">
        <Setter
            Property="Background" Value="{StaticResource ButtonGrayColorBrush}" />
        <Setter
            Property="FontSize"
            Value="{StaticResource FontSizeRegular}" />
        <Setter 
            Property="HorizontalContentAlignment" 
            Value="Center" />
        <Setter 
            Property="BorderThickness"
            Value="0" />
        <Setter 
            Property="Foreground" 
            Value="{StaticResource WhiteColorBrush}" />
        <Setter
            Property="local:ControlIsBusyAttachedproperty.IsBusy"
            Value="False" />
        <Setter
            Property="Template">
            <Setter.Value>
                <ControlTemplate
                    TargetType="{x:Type ButtonBase}">
                    <Border
                        x:Name="Border"
                        CornerRadius="7"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <TextBlock
                                    Text="{TemplateBinding Content}"
                                    Focusable="False"
                                    FontFamily="{TemplateBinding FontFamily}"
                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                    Margin="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Visibility="{TemplateBinding
                                                    local:ControlIsBusyAttachedProperty.IsBusy,
                                                    Converter={StaticResource ReverseBooleanToVisibilityConverter}}" />
                            <local:LoadingSpinnerControl
                                Diameter="20"
                                Thickness="2"
                                Color="{StaticResource BackgroundLightBrush}"
                                IsLoading="{TemplateBinding local:ControlIsBusyAttachedProperty.IsBusy}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger
                            Property="IsMouseOver"
                            Value="True">
                            <Setter
                                Property="Cursor"
                                Value="Hand" />
                            <Setter
                                Property="Background"
                                TargetName="Border"
                                Value="{StaticResource BlackColorBrush}"/>
                        </Trigger>
                        <Trigger
                            Property="IsEnabled"
                            Value="False">
                            <Setter
                                Property="Background"
                                TargetName="Border"
                                Value="{StaticResource BlackColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Стиль для кнопки входа в аккаунт -->
    <Style
        TargetType="{x:Type Button}"
        BasedOn="{StaticResource BaseStyle}"
        x:Key="AuthButton">
        <Setter
            Property="Background" Value="{StaticResource GreenColorBrush}" />
        <Setter
            Property="FontSize"
            Value="{StaticResource FontSizeRegular}" />
        <Setter 
            Property="HorizontalContentAlignment" 
            Value="Center" />
        <Setter 
            Property="BorderThickness"
            Value="0" />
        <Setter 
            Property="Foreground" 
            Value="{StaticResource WhiteColorBrush}" />
        <Setter
            Property="local:ControlIsBusyAttachedproperty.IsBusy"
            Value="False" />
        <Setter
            Property="Template">
            <Setter.Value>
                <ControlTemplate
                    TargetType="{x:Type ButtonBase}">
                    <Border
                        x:Name="Border"
                        CornerRadius="7"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <TextBlock
                                    Text="{TemplateBinding Content}"
                                    Focusable="False"
                                    FontFamily="{TemplateBinding FontFamily}"
                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                    Margin="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Visibility="{TemplateBinding
                                                    local:ControlIsBusyAttachedProperty.IsBusy,
                                                    Converter={StaticResource ReverseBooleanToVisibilityConverter}}" />
                            <local:LoadingSpinnerControl
                                Diameter="20"
                                Thickness="2"
                                Color="{StaticResource WhiteColorBrush}"
                                IsLoading="{TemplateBinding local:ControlIsBusyAttachedProperty.IsBusy}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger
                            Property="IsMouseOver"
                            Value="True">
                            <Setter
                                Property="Cursor"
                                Value="Hand" />
                            <Setter
                                Property="Background"
                                TargetName="Border"
                                Value="{StaticResource GreenColorBrush}"/>
                        </Trigger>
                        <Trigger
                            Property="IsEnabled"
                            Value="False">
                            <Setter
                                Property="Background"
                                TargetName="Border"
                                Value="{StaticResource GreenColorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    s
</ResourceDictionary>