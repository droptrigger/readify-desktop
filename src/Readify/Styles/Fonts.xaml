<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <system:Double 
       x:Key="FontSizeRegular">
        16
    </system:Double>
    <system:Double 
       x:Key="FontSizeSmall">
        14
    </system:Double>
    <system:Double 
       x:Key="FontSizeLarge">
        20
    </system:Double>
    <system:Double 
       x:Key="FontSizeVeryLarge">
        68
    </system:Double>

    <FontFamily 
        x:Key="FontRegular">
        pack://application:,,,/Fonts/Inter-Regular.ttf#Inter Regular
    </FontFamily>
    <FontFamily 
        x:Key="FontBold">
        pack://application:,,,/Fonts/Inter-Bold.ttf#Inter Bold
    </FontFamily>
    <FontFamily 
        x:Key="FontBlack">
        pack://application:,,,/Fonts/Inter-Black.ttf#Inter Black
    </FontFamily>
    <FontFamily 
        x:Key="FontLight">
        pack://application:,,,/Fonts/Inter-Light.ttf#Inter Light
    </FontFamily>
    <FontFamily 
        x:Key="FontMedium">
        pack://application:,,,/Fonts/Inter-Medium.ttf#Inter Medium
    </FontFamily>
    <FontFamily 
        x:Key="FontSemiBold">
        pack://application:,,,/Fonts/Inter-Semi-Bold.ttf#Inter Semi Bold
    </FontFamily>

    <Style
        TargetType="{x:Type Control}"
        x:Key="BaseStyle">
        <Setter
            Property="FontFamily"
            Value="{StaticResource FontRegular}" />
        <Setter
            Property="TextOptions.TextRenderingMode"
            Value="ClearType" />
    </Style>
    <Style
        TargetType="{x:Type TextBlock}"
        x:Key="BaseTextBlockStyle">
        <Setter
            Property="FontFamily"
            Value="{StaticResource FontRegular}" />
        <Setter
            Property="TextOptions.TextRenderingMode"
            Value="ClearType" />
    </Style>

    <Style 
        TargetType="{x:Type Button}"
        BasedOn="{StaticResource BaseStyle}" />
    <Style 
        TargetType="{x:Type Label}" 
        BasedOn="{StaticResource BaseStyle}" />
    <Style 
        TargetType="{x:Type TextBox}" 
        BasedOn="{StaticResource BaseStyle}" />
    <Style 
        TargetType="{x:Type TextBlock}" 
        BasedOn="{StaticResource BaseTextBlockStyle}" />
    <Style 
        TargetType="{x:Type ListView}" 
        BasedOn="{StaticResource BaseStyle}" />

</ResourceDictionary>